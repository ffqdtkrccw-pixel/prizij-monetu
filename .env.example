# Přežij Monetu — Environment Variables
# Zkopíruj do .env.local a vyplň hodnoty z Supabase projektu

# Supabase — veřejné (safe pro klienta)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — tajné (pouze server, NIKDY nekomprimovat do klienta)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vercel Cron secret (chraň endpoint /api/daily-resolution)
CRON_SECRET=vymysli-silny-nahodny-retezec-zde
